PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string (do NOT use localhost in production)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-resume-builder

# Generate a long random string, e.g.: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

GROQ_API_KEY=your_groq_api_key_here

# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_URL=https://your-frontend-domain.com,http://localhost:3000
